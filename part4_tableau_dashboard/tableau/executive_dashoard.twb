      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_0281973551362048]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_0281973551509505]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) - SUM([profit])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0281973551616002]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_0281973551734787]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNT([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='integer' name='[Calculation_0281973552009220]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&#10;&apos;day&apos;,&#10;[order_date],&#10;[ship_date]&#10;)' />
      </column>
      <column caption='bucket' datatype='string' name='[Calculation_0281973552177157]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;=2 THEN &quot;Fast&quot;&#10;ELSEIF [delivery_days] &lt;=5 THEN &quot;Normal&quot;&#10;ELSE &quot;Delayed&quot;&#10;END' />
      </column>
