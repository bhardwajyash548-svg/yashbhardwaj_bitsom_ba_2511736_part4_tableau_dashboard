      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_0245346053984257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_0245346054123522]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) - SUM([profit])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0245346054197251]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='integer' name='[Calculation_0245346054848517]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&#10;&apos;day&apos;,&#10;[order_date],&#10;[ship_date]&#10;)' />
      </column>
      <column caption='bucket' datatype='string' name='[Calculation_0245346055266310]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;=2 THEN &quot;Fast&quot;&#10;ELSEIF [delivery_days] &lt;=5 THEN &quot;Normal&quot;&#10;ELSE &quot;Delayed&quot;&#10;END' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_0245346060181513]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNT([order_id])' />
      </column>
      <column caption='dashboard_sales_data' datatype='table' name='[__tableau_internal_object_id__].[dashboard!sales!data_0C074A70FDB34B86AA89899FD5B072B1]' role='measure' type='quantitative' />
